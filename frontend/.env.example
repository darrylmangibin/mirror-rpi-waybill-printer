# Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Frontend Configuration
# API URL for the React frontend
# IMPORTANT: Include the protocol (http:// or https://)
# For local development: http://localhost:5000
# For remote access from Windows/other devices: http://<raspberry-pi-ip>:5000
# Examples:
#   - http://192.168.1.45:5000 (correct)
#   - 192.168.1.45:5000 (WRONG - missing protocol!)
VITE_API_URL=http://localhost:5000
