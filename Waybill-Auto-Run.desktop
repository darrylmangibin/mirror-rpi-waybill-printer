[Desktop Entry]
Version=1.0
Type=Application
Name=Waybill Auto Run
Comment=Start or restart the RPI Waybill Printer services
Icon=application-x-executable
Exec=bash -c 'sudo systemctl start rpi-waybill-printer-backend.service && sudo systemctl start rpi-waybill-printer-frontend.service && echo "✅ Services started!" && echo "Backend:  http://<your-pi-ip>:5000" && echo "Frontend: http://<your-pi-ip>:5173" && echo "" && echo "Press Enter to close..."; read'
Terminal=true
Categories=Utility;
X-Desktop-File-Install-Version=0.24

