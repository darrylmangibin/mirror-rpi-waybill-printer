# RPI Waybill Printer - Environment Configuration

# Copy: cp .env.example .env (or use: copy .env.example .env on Windows)
# Edit: nano .env (or vim, code, notepad depending on your editor)
# Then fill in your actual configuration values

DEBUG=False
HOST=0.0.0.0
PORT=5000

# Printer Configuration
PRINTER_NAME="XP410B"
# Ex. usb://Xprinter/XP-410B?serial=410BBE235170626
PRINTER_URI="usb://Xprinter/XP-410B?serial=REPLACE_ME"

# Cleanup Config
CLEANUP_INTERVAL_MINUTES = 30  # Run cleanup check every 30 minutes
HOURS_THRESHOLD = 6            # Delete records OLDER than 6 hours (recent data is safe)