# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

APP_ALLOW_DUPLICATE_JOB=false

# Database Configuration
DATABASE_URI=sqlite:///raspberry_pi.db
DATABASE_PATH=/path_from_device/rpi-waybill-printer/backend/raspberry_pi.db

# Print Job Cron Configuration
APP_CRON_ENABLED=true              # Enable/disable the cron job (default: true)

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/path_from_device/rpi-waybill-printer/backend/logs/app.log

# Application Timezone
APP_TIMEZONE=Asia/Manila

# Printer Configuration
# Choose one mode: 'mock', 'cups', or 'escpos'
# PRINTER_MODE options:
#   - mock      : Testing without hardware (default)
#   - cups      : CUPS-based (Epson L120 on local machine)
#   - escpos    : ESC/POS thermal printer (XPrinter on Raspberry Pi)

PRINTER_MODE=mock
PRINT_ENABLED=true

# For CUPS Mode (Epson L120)
# Uncomment and set the printer name from: lpstat -p -d
# PRINTER_NAME=Epson-L120

# For ESC/POS Mode (XPrinter on Raspberry Pi)
# Find USB IDs using: lsusb
# Look for line like: Bus 001 Device 004: ID 04b8:0005 Seiko Epson Corp.
# Then use: ID [vendor]:[product]
# PRINTER_USB_VENDOR=0x04b8
# PRINTER_USB_PRODUCT=0x0005

# Optional: Future API Authentication
# API_SECRET_KEY=your-secret-key-here
# API_TOKEN=your-api-token-here
