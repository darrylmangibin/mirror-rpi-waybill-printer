# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# Database Configuration
DATABASE_URI=sqlite:///raspberry_pi.db
DATABASE_PATH=/path_from_device/rpi-waybill-printer/backend/raspberry_pi.db

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/path_from_device/rpi-waybill-printer/backend/logs/app.log

# Application Timezone
APP_TIMEZONE=Asia/Manila

# Optional: Future API Authentication
# API_SECRET_KEY=your-secret-key-here
# API_TOKEN=your-api-token-here
