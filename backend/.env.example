# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# Database Configuration
DATABASE_URI=sqlite:///raspberry_pi.db
DATABASE_PATH=/path/to/your/raspberry_pi.db

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/path/to/your/logs/app.log

# Optional: Future API Authentication
# API_SECRET_KEY=your-secret-key-here
# API_TOKEN=your-api-token-here
