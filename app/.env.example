# ============================================================================
# Waybill Printer - Environment Configuration Example
# ============================================================================
# Copy this file to .env and update values for your environment
# cp .env.example .env
#
# For detailed configuration documentation, see: PRINTER_CONFIGURATION.md
# ============================================================================

# ============================================================================
# PRINTER SETTINGS
# ============================================================================

# Printer Identification
# Name of the CUPS printer to use. Leave empty to use system default printer.
# Example: XPrinter, NetworkPrinter, ThermalPrinter_80mm
PRINTER_NAME=

# Printer Mode
# Options: "raw" (direct to printer, bypasses format validation) or "standard" (CUPS IPP protocol)
# Use "raw" for thermal printers that don't support PNG/image formats via IPP
# Default: raw
PRINTER_MODE=raw

# ============================================================================
# IMAGE CONVERSION SETTINGS
# ============================================================================

# DPI for PDF to PNG conversion
# 203 DPI is optimal for 80mm thermal printers
# Adjust based on your printer and desired print quality
# Common values: 150, 200, 203, 300
PRINTER_DPI=203

# Convert PDF files to PNG for thermal printer compatibility
# Set to "false" to send PDFs directly (requires printer/driver support)
# Default: true
PRINTER_CONVERT_PDF=true

# Convert color modes (RGBA to RGB) for thermal printer compatibility
# Set to "false" if your printer handles color conversion
# Default: true
PRINTER_CONVERT_COLOR_MODE=true

# ============================================================================
# LABEL DIMENSIONS
# ============================================================================

# AWB (Air Waybill) Label Width in millimeters
# IATA Standard: 102mm (4 inches)
# Adjust based on your label stock
AWB_LABEL_WIDTH_MM=102

# AWB (Air Waybill) Label Height in millimeters
# IATA Standard: 127mm (5 inches)
# Adjust based on your label stock
AWB_LABEL_HEIGHT_MM=127

# ============================================================================
# PRINT OPTIONS
# ============================================================================

# Print Scaling Percentage
# 100 = no scaling, 50 = 50% size, 200 = 200% size
# Default: 100
PRINTER_SCALING=100

# Fit content to page/label
# Set to "true" to automatically scale content to fit the label
# Default: true
PRINTER_FIT_TO_PAGE=true

# ============================================================================
# APPLICATION SETTINGS (if applicable)
# ============================================================================

# Flask Environment
# Options: development, production, testing
FLASK_ENV=production

# Debug Mode (only for development)
DEBUG=false

# Database URL (if applicable)
# DATABASE_URL=

# ============================================================================
# QUICK PRESET CONFIGURATIONS
# ============================================================================

# Uncomment one of these preset configurations based on your printer:

# --- XPrinter 80mm Thermal Printer (Recommended) ---
PRINTER_NAME=XPrinter
PRINTER_MODE=raw
PRINTER_DPI=203
PRINTER_CONVERT_PDF=true
AWB_LABEL_WIDTH_MM=102
AWB_LABEL_HEIGHT_MM=127
PRINTER_SCALING=100
PRINTER_FIT_TO_PAGE=true

# --- Network Printer with Standard CUPS ---
# PRINTER_NAME=NetworkPrinter
# PRINTER_MODE=standard
# PRINTER_DPI=300
# PRINTER_CONVERT_PDF=false
# PRINTER_SCALING=100

# --- 58mm Thermal Printer ---
# PRINTER_NAME=ThermalPrinter58mm
# PRINTER_MODE=raw
# PRINTER_DPI=203
# PRINTER_CONVERT_PDF=true
# AWB_LABEL_WIDTH_MM=80
# AWB_LABEL_HEIGHT_MM=100
# PRINTER_SCALING=100

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
